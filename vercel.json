{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/e/:slug",
      "destination": "/api/og/event/:slug?bySlug=true"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}