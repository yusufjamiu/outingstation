{
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/event/([^/]+)",
      "dest": "/api/og/event/$1",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?!.*Chrome)(?!.*Firefox)(?!.*Safari)(.*)"
        }
      ]
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}