{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/image\\.png",
      "dest": "/image.png"
    },
    {
      "src": "/og-image\\.png",
      "dest": "/og-image.png"
    },
    {
      "src": "/robots\\.txt",
      "dest": "/robots.txt"
    },
    {
      "src": "/sitemap\\.xml",
      "dest": "/sitemap.xml"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/e/([^/]+)",
      "dest": "/api/og/event/$1?bySlug=true"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}